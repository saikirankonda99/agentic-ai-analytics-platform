APP_ENV=development
LOG_LEVEL=INFO
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
STREAMLIT_SERVER_PORT=8501

OPENAI_API_KEY=

DATABASE_URL=sqlite:///data/platform_persistence.db
# WORKFLOW_DATABASE_URL is the single source of truth for workflow history, events, telemetry, agents, and usage.
# If unset, workflow persistence falls back to DATABASE_URL for compatibility.
WORKFLOW_DATABASE_URL=sqlite:///data/workflow_runtime.db
POSTGRES_URL=postgresql://analytics:analytics@localhost:5432/analytics
REDIS_URL=redis://localhost:6379/0
VECTOR_DATABASE_URL=

ORCHESTRATION_QUEUE=orchestration.workflows
WEBSOCKET_CHANNEL_PREFIX=workflow
